# Consistency-weight sweep for PACE-MSE and PACE-KL.
DATASETS="cifar"
SEEDS="42"
LBD_VALUES="0.1 0.25 0.5 1.0"
METHODS="pace pace_kl"
EPOCHS=300
ADAPTER="LoRAmul_VPTadd"
RANK=10
LORA_ALPHA=10
BS=16
OUT_ROOT="outputs/pace_lambda_sweep"
EVAL_ROOT="results/pace_lambda_sweep"
LOG_ROOT="logs/pace_lambda_sweep"
